<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.dailycart.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/dealsFragment"
        android:name="com.example.dailycart.ui.deals.DealsFragment"
        android:label="Deals"
        tools:layout="@layout/fragment_deals" />

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.dailycart.ui.cart.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart" >
        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/ordersFragment"
        android:name="com.example.dailycart.ui.order.OrdersFragment"
        android:label="Orders"
        tools:layout="@layout/fragment_orders" />

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.example.dailycart.ui.checkout.CheckoutFragment"
        android:label="Checkout" >
        <action
            android:id="@+id/action_checkout_to_success"
            app:destination="@id/orderSuccessFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
        <action
            android:id="@+id/action_checkout_to_mockPayment"
            app:destination="@id/mockPaymentFragment" />
        <action
            android:id="@+id/action_checkout_to_addressList"
            app:destination="@id/addressListFragment" />
    </fragment>

    <fragment
        android:id="@+id/addressListFragment"
        android:name="com.example.dailycart.ui.address.AddressListFragment"
        android:label="Saved Addresses"
        tools:layout="@layout/fragment_address_list">
        <action
            android:id="@+id/action_addressList_to_addEditAddress"
            app:destination="@id/addEditAddressFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditAddressFragment"
        android:name="com.example.dailycart.ui.address.AddEditAddressFragment"
        android:label="Manage Address"
        tools:layout="@layout/fragment_add_edit_address">
        <argument
            android:name="address"
            app:argType="com.example.dailycart.data.model.Address"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/orderSuccessFragment"
        android:name="com.example.dailycart.ui.checkout.OrderSuccessFragment"
        android:label="Order Success" />

    <fragment
        android:id="@+id/mockPaymentFragment"
        android:name="com.example.dailycart.ui.payment.MockPaymentFragment"
        android:label="Processing Payment">
        <action
            android:id="@+id/action_payment_to_success"
            app:destination="@id/orderSuccessFragment"
            app:popUpTo="@id/checkoutFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>