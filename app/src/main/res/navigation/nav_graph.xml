<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.dailycart.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" >
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.dailycart.ui.search.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search" >
    </fragment>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.dailycart.ui.cart.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart" >
        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/ordersFragment"
        android:name="com.example.dailycart.ui.order.OrdersFragment"
        android:label="Orders"
        tools:layout="@layout/fragment_orders" />

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.example.dailycart.ui.checkout.CheckoutFragment"
        android:label="Checkout" >

        <action
            android:id="@+id/action_checkout_to_success"
            app:destination="@id/orderSuccessFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/orderSuccessFragment"
        android:name="com.example.dailycart.ui.checkout.OrderSuccessFragment"
        android:label="Order Success" />

    <fragment
        android:id="@+id/mockPaymentFragment"
        android:name="com.example.dailycart.ui.checkout.MockPaymentFragment"
        android:label="Processing Payment">
        <action
            android:id="@+id/action_payment_to_success"
            app:destination="@id/orderSuccessFragment"
            app:popUpTo="@id/homeFragment" />
    </fragment>

</navigation>